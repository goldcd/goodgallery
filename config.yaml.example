# GoodGallery Configuration

gallery:
  # Path to your photo directory (REQUIRED)
  photo_directory: "path/to/your/photos"
  
  # Web server port
  port: 5000
  
  # Monitor photos directory for changes (auto-detect additions/deletions)
  watch_for_changes: true
  
  # Thumbnail settings
  thumbnail_size: 200
  images_per_page: 100
  
  # Allowed image extensions
  allowed_extensions:
    - jpg
    - jpeg
    - png
    - gif
    - webp

ai:
  # - "prithivMLmods/Qwen3-VL-8B-Instruct-abliterated-v1" (Default)
  # - "llava-hf/llava-1.5-7b-hf" (Classic)
  model: "prithivMLmods/Qwen3-VL-8B-Instruct-abliterated-v1"
  
  # Auto-tag images on startup
  auto_tag: false
  
  # Keep model loaded in GPU memory (faster but uses more VRAM)
  keep_model_loaded: false
  
  # Number of images to process per GPU batch
  batch_size: 15
  
  # Enable 4-bit quantization (fits in ~6GB VRAM)
  use_quantization: true

database:
  # SQLite database path
  path: "data/gallery.db"
